# Airtable CMS Environment Variables for Vercel
# Add these to your Vercel project environment variables

# Your Airtable API Key (get this from your Airtable account)
AIRTABLE_API_KEY=your_airtable_api_key_here

# Optional: Base IDs for reference (these are already hardcoded in the API routes)
# Video Production Base ID: appjQxcRoClnZzghj
# Web Development Base ID: appV5l9kZ5vAxcz4e  
# Photography Base ID: appP1uFoRWjxPkQ5b

# Note: The API key should have access to all three bases
# Make sure your Airtable bases are either public or the API key has proper permissions
