# GitHub API Configuration
# Get your token from: https://github.com/settings/tokens
# Requires: repo permissions for your cochran-job-listings repository
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=cochranfilms
GITHUB_REPO=cochran-job-listings
GITHUB_BRANCH=main

# Server Configuration
PORT=3000

# --- Landing site (Vercel: cochran-films-landing, public/ root) ---
# Service Package Builder → Stripe Invoicing + EmailJS

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
# Optional — only if you add client-side Stripe.js later
STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...
# Webhook signing secret — register https://www.cochranfilms.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Days until invoice due (default 30)
STRIPE_INVOICE_DAYS_UNTIL_DUE=30

# EmailJS (Dashboard → Account → API keys, Email Services, Email Templates)
EMAILJS_SERVICE_ID=service_t11yvru
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
# New template — paste HTML from docs/emailjs-service-package-invoice-template.html
EMAILJS_PACKAGE_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_PACKAGE_ADMIN_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_PACKAGE_PAID_ADMIN_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_PACKAGE_PAID_CLIENT_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_PACKAGE_PAYMENT_FAILED_CLIENT_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_PACKAGE_OVERDUE_CLIENT_TEMPLATE_ID=template_xxxxxxxx
# New template — paste HTML from docs/emailjs-contact-inquiry-template.html
EMAILJS_CONTACT_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_CONTACT_TO_EMAIL=info@cochranfilms.com
# EMAILJS_CONTACT_SEND_CLIENT_COPY=false
EMAILJS_ADMIN_EMAIL=cody@cochranfilms.com

SITE_URL=https://www.cochranfilms.com

# CORS — comma-separated origins allowed to call /api/stripe/create-invoice
ALLOWED_ORIGINS=https://www.cochranfilms.com,https://cochranfilms.com,https://landing.cochranfilms.com
