# Stripe Configuration
# Copy this file to .env and fill in your actual keys

# Stripe Secret Key (starts with sk_test_ for testing, sk_live_ for production)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Stripe Publishable Key (starts with pk_test_ for testing, pk_live_ for production)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Stripe Webhook Secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Server Configuration
PORT=3000
NODE_ENV=development
