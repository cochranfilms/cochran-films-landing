{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "modules/**", "use": "@vercel/static" },
    { "src": "CMS/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index2.html"
    },
    {
      "src": "^/blog$",
      "dest": "/blog.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/admin",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
